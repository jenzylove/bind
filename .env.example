# Bind runtime configuration — copy to .env and fill in.
# NEVER commit .env.

PORT=8787

# x402 payment — Agentic Wallet on X Layer (eip155:196)
PAY_TO_ADDRESS=
USDT_ASSET=0x779Ded0c9e1022225f8E0630b35a9b54bE713736
USDT_DECIMALS=6

# Bind service prices (USDT base units)
PRICE_BIND_PLAN=50000
